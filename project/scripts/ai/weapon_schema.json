{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeaponData",
  "description": "Complete schema for IronCore Arena weapon definitions. Supports 12+ weapon variants across ballistic, energy, explosive, and utility archetypes.",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "tier",
    "weight",
    "cost",
    "damage_per_shot",
    "fire_rate",
    "range_min",
    "range_optimal",
    "range_max",
    "accuracy",
    "projectile_type",
    "damage_type",
    "projectile_speed",
    "heat_per_shot",
    "heat_dissipation_per_tick",
    "overheat_threshold"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^wpn_[a-z0-9_]{2,44}$",
      "description": "Unique weapon identifier. Must start with 'wpn_'."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Display name shown in shop and build screens."
    },
    "category": {
      "type": "string",
      "const": "weapon",
      "description": "Must always be 'weapon' for weapon data."
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Tier level (1-5). Higher tiers are stronger but more expensive."
    },
    "weight": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 80.0,
      "description": "Weight in kg. Must fit within chassis weight_capacity."
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000,
      "description": "Credit cost to purchase. 0 = starter weapon."
    },
    "description": {
      "type": "string",
      "maxLength": 256,
      "description": "Flavor text for shop display."
    },
    "damage_per_shot": {
      "type": "number",
      "minimum": 1,
      "maximum": 500,
      "description": "Base damage before range falloff, resistances, and crit."
    },
    "fire_rate": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 10.0,
      "description": "Shots per second. Converted to tick-based cooldown internally: cooldown_ticks = round(60 / fire_rate)."
    },
    "range_min": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Minimum effective range. Below this distance, damage is 0 (arm safety distance)."
    },
    "range_optimal": {
      "type": "number",
      "minimum": 10,
      "maximum": 800,
      "description": "Optimal range where full damage and accuracy apply."
    },
    "range_max": {
      "type": "number",
      "minimum": 20,
      "maximum": 1200,
      "description": "Maximum range. Projectiles despawn at this distance. Damage falls off between optimal and max."
    },
    "accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Base hit probability at optimal range [0.0 - 1.0]. Modified by sensor accuracy_bonus and range falloff."
    },
    "projectile_type": {
      "type": "string",
      "enum": ["ballistic", "beam", "melee", "aoe"],
      "description": "Determines projectile behavior: ballistic=travels over time, beam=instant raycast, melee=instant close-range, aoe=travels then explodes."
    },
    "damage_type": {
      "type": "string",
      "enum": ["ballistic", "energy", "explosive"],
      "description": "Determines which armor resistance applies: resist_ballistic, resist_energy, or resist_explosive."
    },
    "projectile_speed": {
      "type": "number",
      "minimum": 0,
      "maximum": 2000,
      "description": "Projectile travel speed in units/sec. 0 for beam and melee types."
    },
    "projectile_radius": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 30.0,
      "default": 4.0,
      "description": "Collision radius of the projectile entity."
    },
    "splash_radius": {
      "type": "number",
      "minimum": 0,
      "maximum": 200,
      "default": 0,
      "description": "Area-of-effect damage radius. 0 = single target only."
    },
    "splash_falloff": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 3.0,
      "default": 1.0,
      "description": "Splash damage falloff exponent. 1.0=linear, 2.0=quadratic (damage drops faster at edge)."
    },
    "heat_per_shot": {
      "type": "number",
      "minimum": 0,
      "maximum": 50,
      "description": "Heat generated per shot. Accumulates on the weapon slot."
    },
    "heat_dissipation_per_tick": {
      "type": "number",
      "minimum": 0,
      "maximum": 5.0,
      "description": "Heat removed per simulation tick (1/60 sec). Determines sustainable fire rate."
    },
    "overheat_threshold": {
      "type": "number",
      "minimum": 10,
      "maximum": 200,
      "description": "Heat level that triggers overheat lockout. Weapon cannot fire until heat drops to 0."
    },
    "overheat_lockout_ticks": {
      "type": "integer",
      "minimum": 30,
      "maximum": 600,
      "default": 120,
      "description": "Forced cooldown duration in ticks when overheated (120 ticks = 2 seconds)."
    },
    "crit_chance": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 0.5,
      "default": 0.0,
      "description": "Probability of a critical hit [0.0 - 0.5]. Rolled per shot via DeterministicRng."
    },
    "crit_multiplier": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 3.0,
      "default": 1.5,
      "description": "Damage multiplier on critical hit."
    },
    "ammo_capacity": {
      "type": "integer",
      "minimum": -1,
      "maximum": 999,
      "default": -1,
      "description": "Maximum ammo. -1 = unlimited ammo."
    },
    "reload_ticks": {
      "type": "integer",
      "minimum": 0,
      "maximum": 600,
      "default": 0,
      "description": "Ticks required to reload when ammo is depleted. 0 = no reload needed."
    },
    "burst_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 1,
      "description": "Number of shots per burst. fire_rate applies between bursts."
    },
    "burst_delay_ticks": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30,
      "default": 0,
      "description": "Ticks between shots within a burst. 0 = all shots fire simultaneously."
    },
    "spread_angle": {
      "type": "number",
      "minimum": 0,
      "maximum": 45.0,
      "default": 0,
      "description": "Random spread in degrees applied to each shot direction. 0 = perfectly accurate."
    },
    "effects": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["type", "magnitude", "duration_ticks"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["slow", "stun", "burn", "emp", "armor_break"],
            "description": "Effect type. slow=movement speed reduction, stun=full movement+fire lock, burn=damage over time, emp=disable sensors+utility, armor_break=reduce resistances."
          },
          "magnitude": {
            "type": "number",
            "minimum": 0.01,
            "maximum": 1.0,
            "description": "Effect strength. For slow: 0.3 = 30% speed reduction. For burn: damage per tick. For armor_break: resistance reduction."
          },
          "duration_ticks": {
            "type": "integer",
            "minimum": 1,
            "maximum": 600,
            "description": "Effect duration in simulation ticks. 60 ticks = 1 second."
          },
          "tick_interval": {
            "type": "integer",
            "minimum": 0,
            "maximum": 60,
            "default": 0,
            "description": "For periodic effects (burn): ticks between damage applications. 0 = applies once."
          },
          "stacking": {
            "type": "string",
            "enum": ["replace", "refresh", "stack"],
            "default": "refresh",
            "description": "Stacking rule when same effect re-applied. replace=overwrite, refresh=reset duration, stack=additive (max 3 stacks)."
          },
          "max_stacks": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "default": 3,
            "description": "Maximum stacks when stacking='stack'. Each stack adds magnitude additively."
          },
          "apply_chance": {
            "type": "number",
            "minimum": 0.01,
            "maximum": 1.0,
            "default": 1.0,
            "description": "Probability that effect is applied on hit. Rolled via DeterministicRng."
          }
        },
        "additionalProperties": false
      },
      "description": "Status effects applied on hit. Maximum 3 effects per weapon."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "sustained_fire",
          "burst_fire",
          "sniper",
          "close_range",
          "area_damage",
          "support",
          "anti_armor",
          "anti_energy",
          "crowd_control",
          "high_heat",
          "low_heat",
          "starter"
        ]
      },
      "uniqueItems": true,
      "maxItems": 4,
      "description": "Gameplay tags for AI weapon selection and UI filtering."
    },
    "ai_hints": {
      "type": "object",
      "properties": {
        "preferred_range": {
          "type": "string",
          "enum": ["close", "medium", "far"],
          "description": "AI preferred engagement range for bots equipped with this weapon."
        },
        "role_affinity": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tank", "sniper", "scout", "support"]
          },
          "description": "AI roles that synergize well with this weapon."
        }
      },
      "additionalProperties": false,
      "description": "Hints for AI weapon selection and tactical behavior."
    }
  },
  "additionalProperties": false,

