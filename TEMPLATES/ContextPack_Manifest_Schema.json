{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-studio.io/schemas/context-pack-manifest/v1",
  "title": "Context Pack Manifest",
  "description": "Schema for Context Pack manifest files used in agent handoffs",
  "type": "object",
  "required": ["version", "pack_id", "created_at", "source_agent", "context_items"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Manifest schema version"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^pack-[a-z0-9]{12}$",
      "description": "Unique identifier for this context pack"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when pack was created"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional expiration timestamp"
    },
    "source_agent": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+\\.[a-z0-9_-]+$",
      "description": "Agent that created this pack (format: domain.agent)"
    },
    "target_agent": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+\\.[a-z0-9_-]+$",
      "description": "Optional target agent for this pack"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task-[a-z0-9]{12}$",
      "description": "Associated task identifier"
    },
    "context_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "content"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this context item"
          },
          "type": {
            "type": "string",
            "enum": ["text", "code", "json", "binary", "reference", "embedding"],
            "description": "Type of context item"
          },
          "content": {
            "type": "string",
            "description": "Content or reference to content"
          },
          "encoding": {
            "type": "string",
            "enum": ["utf-8", "base64", "gzip", "none"],
            "default": "utf-8"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "Size of content in bytes"
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$",
            "description": "SHA-256 checksum of content"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "default": 5,
            "description": "Priority level (1=lowest, 10=highest)"
          },
          "ttl_seconds": {
            "type": "integer",
            "minimum": 0,
            "description": "Time-to-live in seconds"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "compression": {
          "type": "string",
          "enum": ["none", "gzip", "zstd"]
        },
        "encryption": {
          "type": "string",
          "enum": ["none", "aes-256-gcm"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "custom": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pack_id", "relation"],
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "relation": {
            "type": "string",
            "enum": ["extends", "includes", "replaces"]
          }
        }
      }
    },
    "signatures": {
      "type": "object",
      "properties": {
        "creator": {
          "type": "string",
          "description": "Signature of creating agent"
        },
        "verifier": {
          "type": "string",
          "description": "Optional verification signature"
        }
      }
    }
  },
  "additionalProperties": false
}
